# Copy to `.env` for local dev. Expo only inlines vars prefixed with `EXPO_PUBLIC_`.

# Store hostname (same value as SHOPIFY_STORE in your web repo), e.g. koko-bay.myshopify.com
EXPO_PUBLIC_SHOPIFY_DOMAIN=
# Optional alias — must also be the hostname (never put the API token here)
# EXPO_PUBLIC_SHOPIFY_STORE=koko-bay.myshopify.com

# Storefront API access token only (Admin → Apps → Develop apps → your app → Storefront API → Install → copy)
# Wrong values: shpss_* (client secret), shpat_* (Admin API) — neither works as Storefront token.
EXPO_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Optional (default 2025-01 in code)
# EXPO_PUBLIC_SHOPIFY_STOREFRONT_API_VERSION=2025-01

# --- Koko Bay web products API (optional) ---
# When set, the app loads catalog from your Next site instead of Storefront.
# Your Next app should expose:
#   GET /api/products?all=1  — products (Mongo-backed catalog)
#   GET /api/collections     — published custom + smart Shopify collections (same PIN bypass as products)
#   GET /api/recommendations?handle=...&limit=8 — PDP related products (slim)
#   GET /api/products/recommendations?intent=complementary — optional cart upsells
#   /api/cart, /api/cart/items — Shopify cart (used by the app when this URL is set; ignores Mongo for checkout)
#   POST /api/page-views — logged-in PDP views `{ email, item: productHandle }` (fire-and-forget)
#   GET /api/content/[slug]?country=GB — app_content CMS (returns-info, shipping-info, etc.)
#   GET /api/app-error — global incident banner (Shopify type app_error)
#   GET /api/app-promotion-banner — promotion strip (Shopify type app_promotion_banner)
#   GET /api/delivery-threshold — free delivery minimum GBP (Shopify type delivery_threshold)
#   GET /api/collections-cms — Collections tab tiles (Shopify type collections)
#
# Production / deployed API (no trailing slash)
EXPO_PUBLIC_KOKOBAY_API_BASE_URL=https://kokobay-mizd.vercel.app
# Local Next.js API (used when USE_LOCALHOST=true)
EXPO_PUBLIC_KOKOBAY_API_LOCAL_URL=http://localhost:3000
# true = LOCAL_URL for all Koko Bay API calls (catalog, cart, CMS); false = BASE_URL
# Restart Metro (`pnpm start`) after changing — Expo only reads EXPO_PUBLIC_* at bundle time.
EXPO_PUBLIC_KOKOBAY_USE_LOCALHOST=false
# On a physical device, set LOCAL_URL to your machine LAN IP, e.g. http://192.168.1.42:3000
#
# Legacy alias for production URL only: EXPO_PUBLIC_KOKOBAY_API_URL=
# Optional legacy header — web `/api/products` does not require a key.
# EXPO_PUBLIC_KOKOBAY_PRODUCTS_API_KEY=

# --- Expo Go over the internet (when `pnpm run start:tunnel` fails) ---
# Expo’s built-in tunnel uses shared ngrok and often errors with
# `Cannot read properties of undefined (reading 'body')`. Use your own tunnel:
#
# 1) Terminal A — Metro on LAN (default port 8081):
#    pnpm run start:lan
# 2) Terminal B — expose Metro (pick one):
#    cloudflared tunnel --url http://localhost:8081
#    # or: ngrok http 8081 --host-header=localhost
# 3) Copy the public https URL from that tool, stop Terminal A, then:
#    EXPO_PACKAGER_PROXY_URL=<that-url> pnpm run start:lan
# 4) Scan the new QR in Expo Go (keep both terminals running).
# EXPO_PACKAGER_PROXY_URL=

# --- EAS App Store submit (optional, for local scripts) ---
# Numeric Apple ID from App Store Connect → App → App Information (not the bundle id).
# Prefer setting submit.production.ios.ascAppId in eas.json so `eas submit --non-interactive` works.
# ASC_APP_ID=

# --- Push notifications (Expo + Koko Bay backend) ---
# Uses EXPO_PUBLIC_KOKOBAY_API_BASE_URL for:
#   POST /api/push/register   — device token (app launch; guest or signed-in email)
#   POST /api/push/unregister — remove token on sign-out
# Requires a physical device, EAS projectId in app.json, and a new native build after enabling the plugin.

# --- Google Tag Manager (optional) ---
# Without these, events go to the in-app mock receiver (logged in dev as `[GTM mock]`).
# EXPO_PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX
# Server-side GTM / collect endpoint — set both with container id to enable live sends.
# EXPO_PUBLIC_GTM_ENDPOINT=https://your-gtm-server.example.com/collect
# EXPO_PUBLIC_GTM_DEBUG=1
