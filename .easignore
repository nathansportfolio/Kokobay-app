# EAS upload ignore — extends .gitignore. See https://docs.expo.dev/build-reference/easignore/

# dependencies
node_modules/
.pnpm-store/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (EAS runs prebuild when absent)
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/ios
/android

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.log*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# Dev-only — not needed on EAS builders
docs/
**/*.test.ts
**/*.test.tsx
store/cart-persist.test.ts
