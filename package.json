{
  "name": "Koko Bay",
  "main": "expo-router/entry",
  "version": "1.0.104",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start --go",
    "start:lan": "expo start --dev-client --lan",
    "start:tunnel": "expo start --dev-client --tunnel",
    "reset-project": "node ./scripts/reset-project.js",
    "bump-version": "node ./scripts/bump-app-version.mjs",
    "increment-build": "node ./scripts/increment-build-number.mjs",
    "version:sync": "node ./scripts/sync-remote-build-version.mjs",
    "version:sync-eas": "node ./scripts/sync-build-from-eas.mjs",
    "release": "node ./scripts/release-build.mjs",
    "release:build": "node ./scripts/release-build.mjs --build-only",
    "ios:release": "node ./scripts/ios-release.mjs",
    "ios:eas:build": "node ./scripts/ios-release.mjs --build-only",
    "ios:submit:latest": "eas submit --platform ios --latest --profile production",
    "android:release": "node ./scripts/android-release.mjs",
    "android:eas:build": "node ./scripts/android-release.mjs --build-only",
    "android:submit:latest": "eas submit --platform android --latest --profile production",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "ios:build": "expo run:ios",
    "android:build": "expo run:android",
    "web": "expo start --web",
    "lint": "expo lint",
    "check-api-migration": "node ./scripts/check-api-migration.mjs",
    "verify:android-release": "node ./scripts/verify-android-release.mjs",
    "sync:app-icons": "bash ./scripts/sync-app-icons.sh",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test '**/*.test.ts'",
    "test:auth-refresh": "node --import tsx --test src/core/auth/refresh-customer-session.test.ts",
    "test:cart-integration": "tsx --tsconfig tests/cart/tsconfig.integration.json --import ./tests/cart/setup-globals.mjs --test store/cart.integration.test.ts",
    "test:cart-reliability": "tsx --tsconfig tests/cart/tsconfig.integration.json --import ./tests/cart/setup-globals.mjs --test store/cart-reliability.integration.test.ts && node --import tsx --test store/cart-snapshot-validate.test.ts",
    "push:preview-payload": "node scripts/preview-push-payload.mjs",
    "well-known:generate": "node scripts/generate-well-known.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/instrument-sans": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/slider": "5.0.1",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.0.2",
    "@tanstack/react-query": "^5.100.9",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "klaviyo-expo-plugin": "^0.4.0",
    "klaviyo-react-native-sdk": "^2.4.1",
    "lucide-react-native": "^1.14.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.75.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.2.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jsdom": "26.0.0",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
